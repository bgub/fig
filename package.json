{
  "name": "fig",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "turbo run build --filter=@bgub/fig-server... --filter=@bgub/fig-reconciler... && node benchmarks/reconciler.mjs",
    "build": "turbo run build",
    "check": "turbo run quality",
    "dev": "FIG_DEV_SOURCE=1 turbo run dev --filter=@bgub/fig-start --filter='./apps/*' --ui=tui",
    "fix": "turbo run quality:fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "generate:jsx-attributes": "node scripts/generate-jsx-attributes.mjs",
    "prepare": "./scripts/prepare-effect.sh",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "turbo run test test:bench test:release",
    "test:bench": "node --test benchmarks/*.test.mjs",
    "test:release": "node --test scripts/release/*.test.mts",
    "test:dom": "turbo run test --filter=@bgub/fig-dom",
    "test:e2e": "turbo run test:e2e --concurrency=1 --filter=@bgub/fig-demo-ssr --filter=@bgub/fig-demo-client --filter=@bgub/fig-demo-start --filter=@bgub/fig-demo-payload",
    "test:reconciler": "turbo run test --filter=@bgub/fig-reconciler",
    "test:watch": "vitest",
    "tegami": "node scripts/tegami.mts",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "packages/fig/dist/index.js",
      "limit": "5 kB"
    },
    {
      "name": "fig core without data",
      "path": "packages/fig/dist/index.js",
      "import": "{ createElement, useState, useReactive, readPromise, Suspense }",
      "limit": "1.1 kB"
    },
    {
      "path": "packages/fig-dom/dist/index.js",
      "limit": "33.5 kB"
    },
    {
      "path": "packages/fig-reconciler/dist/index.js",
      "limit": "20.25 kB"
    }
  ],
  "devDependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "@size-limit/preset-small-lib": "^8.2.4",
    "@tsdown/css": "0.22.5",
    "@types/node": "^20.19.0",
    "@vitest/coverage-istanbul": "4.1.10",
    "happy-dom": "^15.11.7",
    "html-element-attributes": "3.5.0",
    "jsr": "0.14.3",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "portless": "^0.14.0",
    "react": "19.2.5",
    "react-reconciler": "0.33.0",
    "size-limit": "^8.2.4",
    "svg-element-attributes": "2.1.0",
    "tegami": "1.2.5",
    "tsdown": "0.22.5",
    "turbo": "2.10.4",
    "typescript": "^5.9.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@9.15.9"
}
