{
  "name": "fig",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "vp run --filter @bgub/fig --filter @bgub/fig-reconciler --filter @bgub/fig-server build && node benchmarks/reconciler.mjs",
    "bench:reconciler": "vp run --filter @bgub/fig --filter @bgub/fig-reconciler --filter @bgub/fig-server build && node benchmarks/reconciler.mjs",
    "build": "sh -c 'missing=; for d in packages/*; do [ -d \"$d/dist\" ] || missing=1; done; if [ -n \"$missing\" ]; then vp run --no-cache --filter \"./packages/*\" build; else vp run --cache --filter \"./packages/*\" build; fi' && vp run --no-cache --filter './apps/*' build",
    "check": "vp check",
    "dev": "vp run --filter '@bgub/fig-start...' build && FIG_DEV_SOURCE=1 FIG_DEV_SERVER_SKIP_SETUP=1 vp run --filter '@bgub/fig-start' --filter './apps/demo-client' --filter './apps/demo-hmr' --filter './apps/demo-payload' --filter './apps/demo-ssr' --filter './apps/demo-start' --parallel --log labeled dev",
    "generate:jsx-attributes": "node scripts/generate-jsx-attributes.mjs",
    "prepare": "./scripts/prepare-effect.sh",
    "test": "vp test && node --test benchmarks/*.test.mjs",
    "test:bench": "node --test benchmarks/*.test.mjs",
    "test:dom": "vp run --filter @bgub/fig-dom test",
    "test:e2e": "vp run --concurrency-limit 1 --filter @bgub/fig-demo-ssr --filter @bgub/fig-demo-client --filter @bgub/fig-demo-start --filter @bgub/fig-demo-payload test:e2e",
    "test:reconciler": "vp run --filter @bgub/fig-reconciler test",
    "test:watch": "vp test watch",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "packages/fig/dist/index.js",
      "limit": "5 kB"
    },
    {
      "name": "fig core without data",
      "path": "packages/fig/dist/index.js",
      "import": "{ createElement, useState, useReactive, readPromise, Suspense }",
      "limit": "1.1 kB"
    },
    {
      "path": "packages/fig-dom/dist/index.js",
      "limit": "30.75 kB"
    },
    {
      "path": "packages/fig-reconciler/dist/index.js",
      "limit": "20.25 kB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^8.2.4",
    "@tsdown/css": "0.21.10",
    "@types/node": "^20.19.0",
    "@vitest/coverage-istanbul": "4.1.5",
    "happy-dom": "^15.11.7",
    "html-element-attributes": "3.5.0",
    "portless": "^0.14.0",
    "react": "19.2.5",
    "react-reconciler": "0.33.0",
    "size-limit": "^8.2.4",
    "svg-element-attributes": "2.1.0",
    "typescript": "^5.9.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
