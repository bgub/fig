{
  "name": "fig",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "check": "vp check",
    "dev": "vp run -r --parallel --log labeled dev",
    "dev:demos": "turbo run dev --filter @bgub/fig-demo-client --filter @bgub/fig-demo-ssr --filter @bgub/fig-demo-rsc --filter @bgub/fig-demo-start --ui=tui",
    "dev:demos:stream": "vp run --filter @bgub/fig-demo-client --filter @bgub/fig-demo-ssr --filter @bgub/fig-demo-rsc --filter @bgub/fig-demo-start --parallel --log labeled dev",
    "prepare": "./scripts/prepare-effect.sh",
    "test": "vp test",
    "test:dom": "vp run --filter @bgub/fig-dom test",
    "test:e2e": "vp run --filter @bgub/fig-demo-ssr --filter @bgub/fig-demo-client test:e2e",
    "test:reconciler": "vp run --filter @bgub/fig-reconciler test",
    "test:watch": "vp test watch",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "packages/fig/dist/index.js",
      "limit": "1 kB"
    },
    {
      "path": "packages/fig-data/dist/index.js",
      "limit": "3.5 kB"
    },
    {
      "path": "packages/fig-dom/dist/index.js",
      "limit": "25 kB"
    },
    {
      "path": "packages/fig-reconciler/dist/index.js",
      "limit": "18 kB"
    },
    {
      "path": "packages/fig-scheduler/dist/index.js",
      "limit": "1 kB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^8.2.4",
    "@tsdown/css": "0.21.10",
    "@types/node": "^20.19.0",
    "@vitest/coverage-istanbul": "4.1.5",
    "happy-dom": "^15.11.7",
    "portless": "^0.14.0",
    "size-limit": "^8.2.4",
    "turbo": "^2.10.2",
    "typescript": "^5.9.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
