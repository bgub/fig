{
  "name": "@bgub/fig-demo-tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite --config vite.config.cjs build",
    "build:e2e": "FIG_DEV_SOURCE=1 turbo run build --filter=@bgub/fig-demo-tanstack-start...",
    "dev": "portless",
    "dev:app": "vite --config vite.config.cjs",
    "serve": "vite --config vite.config.cjs preview",
    "test": "vitest run --config ../../vite.config.ts --passWithNoTests",
    "test:e2e": "sh ../../scripts/free-port.sh 4185 && playwright test"
  },
  "portless": {
    "name": "fig-demo-tanstack-start",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-tanstack-router": "workspace:*",
    "@bgub/fig-tanstack-start": "workspace:*",
    "@tanstack/history": "1.162.0",
    "@tanstack/router-core": "1.171.15",
    "@tanstack/store": "0.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "^20.19.0",
    "tailwindcss": "^4.3.2",
    "vite": "8.1.4"
  }
}
