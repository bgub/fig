{
  "name": "@bgub/fig-demo-tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "build:e2e": "turbo run build --filter=@bgub/fig-demo-tanstack-start...",
    "dev": "portless",
    "dev:app": "node --watch --watch-preserve-output dist/server.js",
    "dev:build": "tsdown --config ../../tsdown.config.ts --watch --no-clean",
    "serve": "node dist/server.js",
    "test": "vitest run --config ../../vite.config.ts --passWithNoTests",
    "test:e2e": "sh ../../scripts/free-port.sh 4185 && playwright test"
  },
  "portless": {
    "name": "fig-demo-tanstack-start",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-tanstack-router": "workspace:*",
    "@bgub/fig-tanstack-start": "workspace:*",
    "@tanstack/history": "1.162.0",
    "@tanstack/router-core": "1.171.15",
    "@tanstack/start-server-core": "1.169.17",
    "@tanstack/store": "0.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2"
  }
}
