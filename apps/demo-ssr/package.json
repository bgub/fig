{
  "name": "@bgub/fig-demo-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "build:e2e": "FIG_DEV_SOURCE=1 turbo run build --filter=@bgub/fig-demo-ssr...",
    "dev": "portless",
    "dev:app": "node --watch --watch-preserve-output dist/server.js",
    "dev:build": "tsdown --config ../../tsdown.config.ts --watch --no-clean",
    "serve": "node dist/server.js",
    "test": "vitest run --config ../../vite.config.ts",
    "test:e2e": "sh ../../scripts/free-port.sh 4181 && playwright test"
  },
  "portless": {
    "name": "fig-demo-ssr",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.0"
  }
}
