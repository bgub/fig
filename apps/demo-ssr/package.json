{
  "name": "@bgub/fig-demo-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "build:e2e": "vp run --filter @bgub/fig-demo-ssr... build",
    "dev": "portless",
    "dev:app": "node ../dev-server.mjs node",
    "dev:build": "vp pack --watch --no-clean",
    "serve": "node dist/server.js",
    "serve:watch": "node --watch dist/server.js",
    "test": "vp test run",
    "test:e2e": "sh ../../scripts/free-port.sh 4181 && playwright test"
  },
  "portless": {
    "name": "fig-demo-ssr",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.0"
  }
}
