{
  "name": "@bgub/fig-demo-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build:e2e": "pnpm --dir ../.. --filter @bgub/fig-demo-ssr... build",
    "dev": "pnpm --filter @bgub/fig build && pnpm --filter @bgub/fig-dom build && pnpm --filter @bgub/fig-server build && pnpm build && pnpm serve",
    "serve": "node dist/server.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
