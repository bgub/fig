{
  "name": "@bgub/fig-demo-start",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "build:e2e": "turbo run build --filter=@bgub/fig-demo-start...",
    "dev": "portless",
    "dev:app": "fig-start dev --tailwind --public-url https://fig-demo-start.localhost/",
    "serve": "node dist/server.js",
    "test": "vitest run --config ../../vite.config.ts --passWithNoTests",
    "test:e2e": "sh ../../scripts/free-port.sh 4183 && playwright test"
  },
  "portless": {
    "name": "fig-demo-start",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "@bgub/fig-start": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.0"
  }
}
