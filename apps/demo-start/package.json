{
  "name": "@bgub/fig-demo-start",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "build:e2e": "vp run --filter @bgub/fig-demo-start... build",
    "dev": "portless",
    "dev:app": "node ../dev-server.mjs start",
    "dev:build": "vp pack --watch --no-clean",
    "serve": "node dist/server.js",
    "serve:watch": "node --watch dist/server.js",
    "test": "vp test run --passWithNoTests",
    "test:e2e": "sh ../../scripts/free-port.sh 4183 && playwright test"
  },
  "portless": {
    "name": "fig-demo-start",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "@bgub/fig-start": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.0"
  }
}
