{
  "name": "@bgub/fig-demo-client",
  "private": true,
  "type": "module",
  "scripts": {
    "build:e2e": "vp run --filter @bgub/fig-demo-client... build",
    "build": "vp pack",
    "dev": "portless",
    "dev:app": "node ../dev-server.mjs static",
    "dev:build": "vp pack --watch",
    "serve": "sh -c 'python3 -m http.server \"${PORT:-4173}\" --bind 127.0.0.1'",
    "test:e2e": "playwright test"
  },
  "portless": {
    "name": "fig-demo-client",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
