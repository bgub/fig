{
  "name": "@bgub/fig-demo-client",
  "private": true,
  "type": "module",
  "scripts": {
    "build:e2e": "FIG_DEV_SOURCE=1 turbo run build --filter=@bgub/fig-demo-client...",
    "build": "tsdown --config ../../tsdown.config.ts",
    "dev": "portless",
    "dev:app": "node ../dev/static-server-cli.mjs",
    "dev:build": "tsdown --config ../../tsdown.config.ts --watch --no-clean",
    "serve": "sh -c 'python3 -m http.server \"${PORT:-4173}\" --bind 127.0.0.1'",
    "test:e2e": "sh ../../scripts/free-port.sh 4182 && playwright test"
  },
  "portless": {
    "name": "fig-demo-client",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
