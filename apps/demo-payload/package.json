{
  "name": "@bgub/fig-demo-payload",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "dev": "portless",
    "dev:app": "node ../dev-server.mjs node",
    "dev:build": "vp pack --watch",
    "serve": "node dist/server.js",
    "serve:watch": "node --watch dist/server.js"
  },
  "portless": {
    "name": "fig-demo-payload",
    "script": "dev:app"
  },
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-devtools": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0"
  }
}
