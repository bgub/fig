{
  "name": "@bgub/fig-start",
  "version": "0.0.1",
  "description": "Fig full-stack framework runtime",
  "keywords": [],
  "homepage": "https://github.com/bgub/fig",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./dev-server": {
      "types": "./dist/dev-server.d.ts",
      "import": "./dist/dev-server.js",
      "default": "./dist/dev-server.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "default": "./dist/internal.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js",
      "default": "./dist/vite/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch --no-clean",
    "test": "vp test run --config ../../vite.config.ts src"
  },
  "author": "Ben Gubler <nebrelbug@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bgub/fig",
    "directory": "packages/fig-start"
  },
  "bugs": {
    "url": "https://github.com/bgub/fig/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-server": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.92",
    "effect": "4.0.0-beta.92"
  },
  "peerDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "postcss": "^8.5.0"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/postcss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
