{
  "name": "@bgub/fig-server",
  "version": "0.1.0-alpha.0",
  "description": "Fig server renderer",
  "keywords": [],
  "homepage": "https://github.com/bgub/fig",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./payload": {
      "types": "./dist/payload.d.ts",
      "import": "./dist/payload.js",
      "default": "./dist/payload.js"
    },
    "./html": {
      "types": "./dist/html-entry.d.ts",
      "import": "./dist/html-entry.js",
      "default": "./dist/html-entry.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts && node ../../scripts/strip-declaration-map-comments.mjs dist",
    "prepack": "pnpm build",
    "test": "vitest run --config ../../vite.config.ts src"
  },
  "author": "Ben Gubler <nebrelbug@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bgub/fig",
    "directory": "packages/fig-server"
  },
  "bugs": {
    "url": "https://github.com/bgub/fig/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@bgub/fig": "workspace:*"
  },
  "devDependencies": {
    "@bgub/fig": "workspace:*"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
