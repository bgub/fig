{
  "name": "@bgub/fig-reconciler",
  "version": "0.0.1",
  "description": "Fig reconciler",
  "keywords": [],
  "homepage": "https://github.com/bgub/fig",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "default": "./dist/devtools.js"
    },
    "./refresh": {
      "types": "./dist/refresh.d.ts",
      "import": "./dist/refresh.js",
      "default": "./dist/refresh.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack && node ../../scripts/strip-declaration-map-comments.mjs dist",
    "dev": "vp pack --watch --no-clean",
    "prepack": "vp pack && node ../../scripts/strip-declaration-map-comments.mjs dist",
    "test": "vp test run --config ../../vite.config.ts src"
  },
  "author": "Ben Gubler <nebrelbug@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bgub/fig",
    "directory": "packages/fig-reconciler"
  },
  "bugs": {
    "url": "https://github.com/bgub/fig/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@bgub/fig": "0.0.1"
  },
  "devDependencies": {
    "@bgub/fig": "0.0.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
