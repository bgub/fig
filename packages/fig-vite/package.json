{
  "name": "@bgub/fig-vite",
  "version": "0.0.1",
  "private": true,
  "description": "Fig Vite plugins (Fast Refresh / HMR and data-resource transforms)",
  "keywords": [],
  "homepage": "https://github.com/bgub/fig",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack && node ../../scripts/strip-declaration-map-comments.mjs dist",
