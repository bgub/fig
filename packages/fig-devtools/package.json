{
  "name": "@bgub/fig-devtools",
  "version": "0.0.1",
  "private": true,
  "description": "In-page DevTools for Fig",
  "keywords": [],
  "homepage": "https://github.com/bgub/fig",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack && node ../../scripts/strip-declaration-map-comments.mjs dist",
    "dev": "vp pack --watch --no-clean",
    "test": "vp test run --config ../../vite.config.ts src"
  },
  "author": "Ben Gubler <nebrelbug@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bgub/fig",
    "directory": "packages/fig-devtools"
  },
  "bugs": {
    "url": "https://github.com/bgub/fig/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@bgub/fig": "workspace:*",
    "@bgub/fig-dom": "workspace:*",
    "@bgub/fig-reconciler": "workspace:*"
  },
  "peerDependencies": {
    "@bgub/fig-server": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@bgub/fig-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bgub/fig-server": "workspace:*"
  }
}
